<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.LearnBridge" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>
        <item name="android:textViewStyle">@style/LearnBridgeTextView</item>
        <item name="android:editTextStyle">@style/LearnBridgeEditText</item>
        <item name="materialButtonStyle">@style/LearnBridgeButton</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <style name="LearnBridgeTextView" parent="@android:style/Widget.TextView">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">true</item>
    </style>

    <style name="LearnBridgeEditText" parent="@android:style/Widget.EditText">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <style name="LearnBridgeButton" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>
